# GraphRAG - Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayıp `.env` olarak kaydedin ve değerleri doldurun:
#   cp .env.example .env

# -------------------------------------------------------
# Google Gemini API Anahtarı
# https://aistudio.google.com/app/apikey adresinden alın
# -------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# -------------------------------------------------------
# Neo4j Veritabanı Şifresi
# Docker Compose bu değeri kullanarak Neo4j'yi başlatır.
# İlk kurulumda kendiniz belirleyin (en az 8 karakter).
# -------------------------------------------------------
NEO4J_PASSWORD=your_neo4j_password_here

# -------------------------------------------------------
# (Opsiyonel) Neo4j bağlantı adresi
# Varsayılan: bolt://localhost:7687
# -------------------------------------------------------
# NEO4J_URI=bolt://localhost:7687

# -------------------------------------------------------
# (Opsiyonel) Neo4j kullanıcı adı
# Varsayılan: neo4j
# -------------------------------------------------------
# NEO4J_USERNAME=neo4j

# -------------------------------------------------------
# (Opsiyonel) Log seviyesi: DEBUG | INFO | WARNING | ERROR
# -------------------------------------------------------
# LOG_LEVEL=INFO
